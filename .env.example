# Copy to `.env` and fill in. `.env` is gitignored and dockerignored.

# ── Model selection (provider-agnostic) ──────────────────────────────────────
# Pick models here as "provider:model". Swapping providers is a ONE-LINE change:
# the code passes these to LangChain's init_chat_model(), which dispatches to the
# right provider. No code edits needed to switch.
CHAT_MODEL=anthropic:claude-sonnet-4-6
# e.g. openai:gpt-5.5  ·  google_genai:gemini-3.5-flash  ·  ollama:llama4 (local)

# Embeddings are a SEPARATE model type from the chat model (swapping chat provider
# does not supply one). Default is a local, no-API-key model.
#
# Supported values:
#   local                          → HuggingFace all-MiniLM-L6-v2 (downloaded on first use,
#                                    cached to ~/.cache/huggingface, ~80 MB, no API key)
#   openai:text-embedding-3-small  → OpenAI embeddings (reads OPENAI_API_KEY below)
#   openai:text-embedding-3-large  → OpenAI embeddings, higher dimensionality
#
# NOTE: changing this later requires re-running `make ingest` — vectors from
# different embedding models aren't comparable, so the KB must be rebuilt.
EMBEDDINGS_MODEL=local

# ── Provider credentials ─────────────────────────────────────────────────────
# Set the key for WHICHEVER provider(s) you selected above. These variable names
# are fixed by each provider's SDK (LangChain/the SDK auto-discovers them) — they
# are NOT chosen by this project, which is why they're provider-specific rather
# than a single generic LLM_API_KEY. Set the one(s) you use; leave the rest unset.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# GOOGLE_API_KEY=
# VOYAGE_API_KEY=

# ── Graph tuning ─────────────────────────────────────────────────────────────
# How many times the Verifier may reject a draft verdict before the loop is
# capped and the verdict is downgraded. The LangGraph recursion_limit is an
# independent hard cap that bounds the loop regardless of this value.
# MAX_VERIFIER_ATTEMPTS=3

# ── Optional: tracing (M8) ───────────────────────────────────────────────────
# Nothing leaves the machine unless these are set.
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=agentic-compliance
